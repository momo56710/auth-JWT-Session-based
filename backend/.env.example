# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real secrets.

# ── Google OAuth ───────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
# → Create Credentials → OAuth 2.0 Client ID → Web application
# Authorized redirect URI: http://localhost:8000/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:8000/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── URLs (change for production) ───────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
